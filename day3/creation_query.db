CREATE DATABASE IMDB ;

USE IMDB;


SHOW TABLES;

CREATE TABLE ACTOR(
    aid INT PRIMARY KEY,
    fname VARCHAR(50),
    lname VARCHAR(50),
    gender ENUM ('MALE','FEMALE','OTHER')
);

CREATE TABLE MOVIE(
    mid VARCHAR(15) PRIMARY KEY,
    name VARCHAR(100),
    m_year INT,
    m_rank INT
);

CREATE TABLE DIRECTOR(
    did INT PRIMARY KEY,
    fname VARCHAR(50),
    lname VARCHAR(50)
);


CREATE Table CASTING (
    aid INT,
    mid varchar(15),
    CONSTRAINT fk_aid FOREIGN KEY(aid) REFERENCES ACTOR(aid),
    CONSTRAINT fk_mid FOREIGN KEY(mid) REFERENCES MOVIE(mid),
    role VARCHAR(100)

);

CREATE TABLE MOVIE_DIRECTOR(
    did INT,
    mid VARCHAR(15),
    CONSTRAINT fkm_did FOREIGN KEY(did) REFERENCES DIRECTOR(did),
    CONSTRAINT fkm_mid FOREIGN KEY(mid) REFERENCES MOVIE(mid)
);


CREATE TABLE GENRE(
    type VARCHAR(50),
    mid VARCHAR(15),
    CONSTRAINT 
)



